-- ===== TWEEN 350 SPEED =====
local lastTP=tick()
function TweenTo(pos)
    if not HRP then return end
    local dist=(pos.Position-HRP.Position).Magnitude
    local tween=TS:Create(HRP,TweenInfo.new(dist/TweenSpeed,Enum.EasingStyle.Linear),{CFrame=pos})
    tween:Play()
    local nc nc=RunService.Stepped:Connect(function()
        if tween.PlaybackState==Enum.PlaybackState.Playing then
            for _,p in pairs(Char:GetChildren()) do if p:IsA("BasePart") then p.CanCollide=false end end
        else nc:Disconnect() end
    end)
    tween.Completed:Wait()
end

function TeleportTo(pos)
    if not HRP then return end
    local now=tick()
    if now-lastTP<0.5 then TweenTo(pos) return end
    lastTP=now HRP.CFrame=pos
end

function Click() VIM:SendMouseButtonEvent(0,0,0,true,g,0) task.wait(0.05) VIM:SendMouseButtonEvent(0,0,0,false,g,0) end

function GetNearestEnemy(name)
    local n,md=nil,math.huge
    for _,v in pairs(WS.Enemies:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health>0 and v:FindFirstChild("HumanoidRootPart") then
            if string.find(string.lower(v.Name),string.lower(name)) then
                local d=(HRP.Position-v.HumanoidRootPart.Position).Magnitude
                if d<md then md=d n=v end
            end
        end
    end
    return n
end

