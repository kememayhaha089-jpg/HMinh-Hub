    bv.Parent = HRP
end

function DisableFly()
    if HRP then
        for _, v in pairs({HRP:FindFirstChild("FlyGyro"), HRP:FindFirstChild("FlyVel")}) do
            if v then v:Destroy() end
        end
    end
end

