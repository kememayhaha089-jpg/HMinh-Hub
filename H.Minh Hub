local function ExecuteCombo(targetPlayer)
    if not targetPlayer or targetPlayer == LP then return end
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local targetHRP = targetPlayer.Character.HumanoidRootPart
    pcall(function() WS.CurrentCamera.CFrame = CFrame.new(WS.CurrentCamera.CFrame.Position, targetHRP.Position) end)
    HRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
    for _, key in pairs(ComboSequence) do
        local kc = Enum.KeyCode[key]
        if kc then
            VIM:SendKeyEvent(true, kc, false, g)
            task.wait(0.1)
            VIM:SendKeyEvent(false, kc, false, g)
            task.wait(0.3)
        end
    end
end

