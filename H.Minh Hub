local function TweenTo(pos)
    local tween = TS:Create(HRP, TweenInfo.new(0.5), {CFrame = pos})
    tween:Play()
end

local function TeleportTo(pos)
    if HRP then HRP.CFrame = pos end
end

local function Click()
    VIM:SendMouseButtonEvent(0, 0, 0, true, g, 0)
    task.wait(0.05)
    VIM:SendMouseButtonEvent(0, 0, 0, false, g, 0)
end

local function GetNearestEnemy(name)
    local nearest, minDist = nil, math.huge
    for _, v in pairs(WS.Enemies:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            if string.find(string.lower(v.Name), string.lower(name)) then
                local dist = (HRP.Position - v.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = v
                end
            end
        end
    end
    return nearest
end

