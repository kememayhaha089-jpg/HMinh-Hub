--[[
    Redz Hub Script - Display Image by ID in Right Corner
    Image ID: 129898296854108
    Compatible: All Executors
--]]

-- Load RedzLib
local RedzLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/REDzHUB/RedzLib/main/Library.lua"))()

-- Create Window
local Window = RedzLib:CreateWindow("Redz Hub - Right Corner Image", "By Redz Hub", Vector2.new(400, 300), Enum.KeyCode.RightControl)
local Tab = Window:CreateTab("Image Control")

-- Roblox Image ID
local IMAGE_ID = "129898296854108"
local IMAGE_LINK = "rbxassetid://" .. IMAGE_ID

-- Create ScreenGui
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "RedzRightImage"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = game:GetService("CoreGui")

-- Create Container Frame
local Frame = Instance.new("Frame")
Frame.Name = "ImageFrame"
Frame.Size = UDim2.new(0, 310, 0, 310)
Frame.Position = UDim2.new(1, -320, 0, 10)
Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Frame.BorderSizePixel = 0
Frame.Active = true
Frame.Draggable = true
Frame.Parent = ScreenGui

-- Corner Radius
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 10)
UICorner.Parent = Frame

-- Red Border
local Stroke = Instance.new("UIStroke")
Stroke.Thickness = 2
Stroke.Color = Color3.fromRGB(255, 50, 50)
Stroke.Parent = Frame

-- Main Image
local Image = Instance.new("ImageLabel")
Image.Name = "RedzImage"
Image.Image = IMAGE_LINK
Image.BackgroundTransparency = 1
Image.Size = UDim2.new(1, -10, 1, -10)
Image.Position = UDim2.new(0, 5, 0, 5)
Image.ScaleType = Enum.ScaleType.Fit
Image.Parent = Frame

-- Close Button (X)
local CloseBtn = Instance.new("TextButton")
CloseBtn.Name = "CloseButton"
CloseBtn.Text = "✕"
CloseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
CloseBtn.TextSize = 18
CloseBtn.Font = Enum.Font.GothamBold
CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
CloseBtn.Size = UDim2.new(0, 30, 0, 30)
CloseBtn.Position = UDim2.new(1, -35, 0, 5)
CloseBtn.ZIndex = 10
CloseBtn.Parent = Frame

-- Close Button Corner
local CloseCorner = Instance.new("UICorner")
CloseCorner.CornerRadius = UDim.new(0, 15)
CloseCorner.Parent = CloseBtn

-- Close Event
CloseBtn.MouseButton1Click:Connect(function()
    Frame.Visible = false
end)

-- ===== CONTROL BUTTONS =====
Tab:CreateLabel("Image ID: " .. IMAGE_ID)

Tab:CreateButton("Show Image 👁️", function()
    Frame.Visible = true
end)

Tab:CreateButton("Hide Image ❌", function()
    Frame.Visible = false
end)

Tab:CreateTextBox("Change Image ID 🖼️", IMAGE_ID, function(text)
    Image.Image = "rbxassetid://" .. text
end)

Tab:CreateSlider("Size 📏", 100, 500, 300, function(value)
    Frame.Size = UDim2.new(0, value + 10, 0, value + 10)
end)

Tab:CreateSlider("Transparency 🌫️", 0, 1, 0, function(value)
    Image.ImageTransparency = value
end)

Tab:CreateButton("Reset Position 🔄", function()
    Frame.Position = UDim2.new(1, -320, 0, 10)
end)

Tab:CreateButton("Refresh Image 🔄", function()
    Image.Image = ""
    wait(0.1)
    Image.Image = IMAGE_LINK
end)

-- Startup Notification
RedzLib:Notification("Redz Hub", "Image loaded! ID: " .. IMAGE_ID .. " | Check right corner.", 5)
