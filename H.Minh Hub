local function ExecuteCombo(EnemyPlayer)
    if not EnemyPlayer or not EnemyPlayer.Character or not EnemyPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    if EnemyPlayer == LP then return end

    local TargetHRP = EnemyPlayer.Character.HumanoidRootPart
    
    -- Aimbot khóa mục tiêu
    pcall(function()
        WS.CurrentCamera.CFrame = CFrame.new(WS.CurrentCamera.CFrame.Position, TargetHRP.Position)
    end)
    
    -- Teleport ra sau lưng đối thủ
    local behindTarget = TargetHRP.CFrame * CFrame.new(0, 0, 3)
    HRP.CFrame = behindTarget
    
    -- Thực hiện combo
    for _, key in pairs(ComboSequence) do
        local keyCode = Enum.KeyCode[key]
        if keyCode then
            VIM:SendKeyEvent(true, keyCode, false, g)
            task.wait(0.1)
            VIM:SendKeyEvent(false, keyCode, false, g)
            task.wait(0.3)
        end
    end
end

